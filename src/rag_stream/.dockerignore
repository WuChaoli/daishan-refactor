# ============================================================
# Docker Build Context Exclusions
# ============================================================
# Purpose: Prevent sensitive files and unnecessary artifacts
# from entering the Docker build context, improving security
# and reducing image size.
# ============================================================

# Environment files (secrets - never copy into image)
.env
.env.*
*.env
!.env.example

# Version control
.git
.gitignore
.gitattributes

# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# Test and coverage artifacts
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
tests/
test/

# Logs (containers should log to stdout)
logs/
*.log

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Documentation (not needed in production image)
docs/
*.md
!README.md

# Local development artifacts
.log-manager/
.ruff_cache/
.mypy_cache/

# Docker files themselves (avoid recursive issues)
Dockerfile*
docker-compose*.yml
.dockerignore

# Node modules (if any)
node_modules/

# Temporary files
tmp/
temp/
*.tmp
