      },
      "description": "边界情况：空字符串"
    },
    {
      "id": "case_010",
      "category": "boundary",
      "input": "岱山石化有限公司是一家大型石化企业，主要生产各种石油化工产品，位于浙江省舟山市岱山县大鱼山岛，是该地区重要的工业支柱企业，为地方经济发展做出了重要贡献，公司拥有先进的生产设备和完善的管理体系",
      "expected_patterns": {
        "should_not_contain": ["岱山石化有限公司"],
        "should_contain": ["石化", "企业"]
      },
      "description": "边界情况：超长 query (> 200 字符)"
    },
    {
      "id": "case_011",
      "category": "boundary",
      "input": "！？。，、；：\"",
      "expected_patterns": {
        "should_not_contain": [],
