{
  "test_cases": [
    {
      "id": "case_001",
      "category": "typical_company",
      "input": "岱山石化有限公司今年的产值是多少",
      "expected_patterns": {
        "should_not_contain": ["岱山石化有限公司"],
        "should_contain": ["产值", "多少"]
      },
      "description": "典型企业名改写：岱山石化有限公司"
    },
    {
      "id": "case_002",
      "category": "typical_company",
      "input": "舟山港务集团的吞吐量如何",
      "expected_patterns": {
        "should_not_contain": ["舟山港务集团"],
        "should_contain": ["吞吐量", "如何"]
      },
      "description": "典型企业名改写：舟山港务集团"
    },
    {
      "id": "case_003",
      "category": "typical_company",
      "input": "浙江石化股份有限公司有几个厂区",
      "expected_patterns": {
        "should_not_contain": ["浙江石化股份有限公司"],
        "should_contain": ["厂区", "几个"]
      },
      "description": "典型企业名改写：浙江石化股份有限公司"
    },
    {
      "id": "case_004",
      "category": "typical_company",
      "input": "大鱼山电厂的装机容量",
      "expected_patterns": {
        "should_not_contain": ["大鱼山电厂"],
        "should_contain": ["装机容量"]
      },
      "description": "典型企业名改写：大鱼山电厂"
    },
    {
      "id": "case_005",
      "category": "complex_structure",
      "input": "岱山石化有限公司和舟山港务集团的产值对比",
      "expected_patterns": {
        "should_not_contain": ["岱山石化有限公司", "舟山港务集团"],
        "should_contain": ["产值", "对比"]
      },
      "description": "包含多个企业名的句子"
    },
    {
      "id": "case_006",
      "category": "complex_structure",
      "input": "你知道岱山石化有限公司的地址吗",
      "expected_patterns": {
        "should_not_contain": ["岱山石化有限公司"],
        "should_contain": ["地址", "知道", "吗"]
      },
      "description": "企业名在句子中间位置的句子"
    },
    {
      "id": "case_007",
      "category": "no_company",
      "input": "今天的天气怎么样",
      "expected_patterns": {
        "should_not_contain": [],
        "should_contain": ["天气", "怎么样"]
      },
      "description": "无企业名 query，期望保持原样"
    },
    {
      "id": "case_008",
      "category": "no_company",
      "input": "园区有多少家企业",
      "expected_patterns": {
        "should_not_contain": [],
        "should_contain": ["园区", "多少家", "企业"]
      },
      "description": "无企业名 query，期望保持原样"
    },
    {
      "id": "case_009",
      "category": "boundary",
      "input": "",
      "expected_patterns": {
        "should_not_contain": [],
